# Streamlit Community Cloud - Secrets
# Copy this to .streamlit/secrets.toml and fill in your keys
# DO NOT commit secrets.toml to GitHub

# Copia este contenido en Streamlit Community Cloud > Advanced Settings > Secrets
# NO subir este archivo con keys reales a GitHub
GEMINI_API_KEY = "TU_GEMINI_API_KEY_AQUI"
GROQ_API_KEY = "TU_GROQ_API_KEY_AQUI"
GROQ_API_KEY = "your_groq_api_key_here"

# Chroma Cloud (optional - free tier: 50K docs)
# Get key at https://app.trychroma.com
# CHROMA_API_KEY = "your_chroma_api_key"
# CHROMA_COLLECTION = "peptibro_clinical"
